# TinyBrain .gitignore

# Swift Package Manager
.build/
.swiftpm/
Package.resolved
*.xcodeproj
xcuserdata/
DerivedData/

# Xcode
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.xcworkspace
!default.xcworkspace
*.xccheckout
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Models (keep repo lightweight)
Models/*
!Models/.gitkeep
*.tbf
*.gguf
*.safetensors
*.bin

# Python (converter scripts)
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/
*.egg-info/
.pytest_cache/

# Documentation build artifacts
.docc-build/
docs/.build/

# Internal planning docs (kept locally, not published)
docs/prd.md
docs/TASK-ROADMAP.md
docs/release-checklist.md
docs/v0.2.0-PLAN.md
docs/REVIEW-HITLER-*
docs/TB-*
docs/tasks/

# Internal project files (kept locally, not published)
CLAUDE.md
AGENTS.md
Scripts/diagnose_model_dims.swift
Scripts/fix_model_vocab.swift
Scripts/fix_vocab_size.swift
Scripts/inspect_model.swift
Scripts/test_model_loading.swift

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Coverage
*.profdata
*.profraw
*.coverage

# Logs
*.log

# Temporary files
*.tmp
.temp/

# Benchmarks output
benchmarks/results/*.json
!benchmarks/results/.gitkeep

.cursor/
.claude/worktrees/

# Cross-team dependency sources cloned locally for development
# (see Sources/TinyBrainCartographerBridge/README.md).
Dependencies/
